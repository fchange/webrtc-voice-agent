SIGNAL_ADDR=:8080
SIGNAL_PUBLIC_WS_URL=ws://localhost:8080/ws
SIGNAL_DEV_TOKEN=dev-token
SIGNAL_BOT_BASE_URL=http://localhost:8081

BOT_ADDR=:8081
BOT_PUBLIC_RTC_IP=127.0.0.1
BOT_STUN_URL=stun:stun.l.google.com:19302
BOT_IDLE_TIMEOUT=2m
BOT_SIGNAL_WS_URL=ws://localhost:8080/ws
BOT_SIGNAL_TOKEN=dev-token

# VAD provider
VAD_PROVIDER=modelscope-fsmn
VAD_MODE=server
VAD_MODELSCOPE_MODEL_ID=damo/speech_fsmn_vad_zh-cn-16k-common-pytorch
VAD_RUNTIME=funasr
VAD_SAMPLE_RATE=16000
VAD_ENDPOINTING_SILENCE_MS=900

# ASR provider
ASR_PROVIDER=xfyun-spark-iat
ASR_XFYUN_WS_URL=wss://iat.xf-yun.com/v1
ASR_XFYUN_HOST=iat.xf-yun.com
ASR_XFYUN_REQUEST_PATH=/v1
ASR_XFYUN_APP_ID=your_app_id
ASR_XFYUN_API_KEY=your_api_key
ASR_XFYUN_API_SECRET=your_api_secret
ASR_XFYUN_LANGUAGE=zh_cn
ASR_XFYUN_DOMAIN=slm
ASR_XFYUN_ACCENT=mandarin
ASR_XFYUN_SAMPLE_RATE=16000
ASR_XFYUN_AUDIO_ENCODING=raw
ASR_XFYUN_EOS_MS=6000
ASR_XFYUN_DWA=wpgs

# Volc/Doubao ASR provider (WebSocket bigmodel streaming)
# Provider id: volc-doubao-asr
# Resource ID examples:
# - volc.bigasr.sauc.duration (按时长计费)
# - volc.bigasr.sauc.concurrent (按并发计费)
ASR_VOLC_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
ASR_VOLC_APP_ID=your_app_id
ASR_VOLC_ACCESS_TOKEN=your_access_token
ASR_VOLC_RESOURCE_ID=volc.bigasr.sauc.duration
ASR_VOLC_LANGUAGE=zh-CN
ASR_VOLC_SAMPLE_RATE=16000
ASR_VOLC_CHUNK_MS=200

# LLM provider
LLM_PROVIDER=openai-compatible-chat-completions
LLM_SEGMENTER_MODE=punctuation_boundary
LLM_SEGMENTER_PUNCTUATION="。！？；!?;"
LLM_OPENAI_COMPAT_BASE_URL=https://ai.gitee.com/v1/chat/completions
LLM_OPENAI_COMPAT_API_KEY=your_openai_compatible_api_key
LLM_OPENAI_COMPAT_MODEL=Qwen2-7B-Instruct
LLM_OPENAI_COMPAT_SYSTEM_PROMPT="You are a concise and helpful Chinese voice assistant."
LLM_OPENAI_COMPAT_MAX_TOKENS=512
LLM_OPENAI_COMPAT_TEMPERATURE=0.7
LLM_OPENAI_COMPAT_TOP_P=0.7
LLM_OPENAI_COMPAT_TOP_K=50
LLM_OPENAI_COMPAT_FAILOVER_ENABLED=true
LLM_OPENAI_COMPAT_TIMEOUT=45s

# Volc Ark LLM (OpenAI-compatible)
# Example:
# LLM_OPENAI_COMPAT_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# LLM_OPENAI_COMPAT_API_KEY=your_ark_bearer_token
# LLM_OPENAI_COMPAT_MODEL=doubao-1-5-lite-32k-250115
# LLM_OPENAI_COMPAT_TOP_K=0

# TTS provider
TTS_PROVIDER=xfyun-tts
TTS_XFYUN_WS_URL=wss://tts-api.xfyun.cn/v2/tts
TTS_XFYUN_HOST=tts-api.xfyun.cn
TTS_XFYUN_REQUEST_PATH=/v2/tts
TTS_XFYUN_APP_ID=your_app_id
TTS_XFYUN_API_KEY=your_api_key
TTS_XFYUN_API_SECRET=your_api_secret
TTS_XFYUN_VOICE=xiaoyan
TTS_XFYUN_TEXT_ENCODING=utf8
TTS_XFYUN_AUDIO_ENCODING=raw
TTS_XFYUN_AUDIO_FORMAT=audio/L16;rate=16000
TTS_XFYUN_PCM_ENDIAN=little
TTS_XFYUN_SAMPLE_RATE=16000
TTS_XFYUN_SPEED=50
TTS_XFYUN_VOLUME=50
TTS_XFYUN_PITCH=50
TTS_XFYUN_BACKGROUND=0
TTS_DEBUG_DUMP_DIR=

# Volc/Doubao TTS provider (HTTP one-shot)
# Provider id: volc-doubao-tts
TTS_VOLC_BASE_URL=https://openspeech.bytedance.com/api/v1/tts
TTS_VOLC_ACCESS_TOKEN=your_access_token
TTS_VOLC_APP_ID=your_app_id
TTS_VOLC_RESOURCE_ID=volc.service_type.10029
TTS_VOLC_CLUSTER=volcano_tts
TTS_VOLC_VOICE_TYPE=BV700_streaming
TTS_VOLC_ENCODING=pcm
TTS_VOLC_SAMPLE_RATE=16000
TTS_VOLC_SPEED_RATIO=1.0
TTS_VOLC_VOLUME_RATIO=1.0
TTS_VOLC_PITCH_RATIO=1.0
TTS_VOLC_TIMEOUT=20s

WEB_SIGNAL_HTTP_URL=http://localhost:8080
WEB_SIGNAL_WS_URL=ws://localhost:8080/ws
WEB_DEV_TOKEN=dev-token
