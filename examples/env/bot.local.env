BOT_ADDR=:8081
BOT_PUBLIC_RTC_IP=127.0.0.1
BOT_STUN_URL=stun:stun.l.google.com:19302
BOT_IDLE_TIMEOUT=2m
BOT_SIGNAL_WS_URL=ws://localhost:8080/ws
BOT_SIGNAL_TOKEN=dev-token

VAD_PROVIDER=modelscope-fsmn
VAD_MODE=server
VAD_MODELSCOPE_MODEL_ID=damo/speech_fsmn_vad_zh-cn-16k-common-pytorch
VAD_RUNTIME=funasr
VAD_SAMPLE_RATE=16000
VAD_ENDPOINTING_SILENCE_MS=900

ASR_PROVIDER=volc-doubao-asr
ASR_VOLC_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
ASR_VOLC_APP_ID=your_volc_app_id
ASR_VOLC_ACCESS_TOKEN=your_volc_access_token
ASR_VOLC_RESOURCE_ID=volc.bigasr.sauc.duration
ASR_VOLC_LANGUAGE=zh-CN
ASR_VOLC_SAMPLE_RATE=16000
ASR_VOLC_CHUNK_MS=200

LLM_PROVIDER=openai-compatible-chat-completions
LLM_SEGMENTER_MODE=punctuation_boundary
LLM_SEGMENTER_PUNCTUATION=。！？；!?;
LLM_OPENAI_COMPAT_BASE_URL=https://ai.gitee.com/v1/chat/completions
LLM_OPENAI_COMPAT_API_KEY=your_openai_compatible_api_key
LLM_OPENAI_COMPAT_MODEL=Qwen2-7B-Instruct
LLM_OPENAI_COMPAT_SYSTEM_PROMPT=You are a concise and helpful Chinese voice assistant.
LLM_OPENAI_COMPAT_MAX_TOKENS=512
LLM_OPENAI_COMPAT_TEMPERATURE=0.7
LLM_OPENAI_COMPAT_TOP_P=0.7
LLM_OPENAI_COMPAT_TOP_K=50
LLM_OPENAI_COMPAT_FAILOVER_ENABLED=true
LLM_OPENAI_COMPAT_TIMEOUT=45s

TTS_PROVIDER=volc-doubao-tts
TTS_VOLC_BASE_URL=https://openspeech.bytedance.com/api/v1/tts
TTS_VOLC_ACCESS_TOKEN=your_volc_access_token
TTS_VOLC_APP_ID=your_volc_app_id
TTS_VOLC_RESOURCE_ID=volc.service_type.10029
TTS_VOLC_CLUSTER=volcano_tts
TTS_VOLC_VOICE_TYPE=BV007_streaming
TTS_VOLC_ENCODING=pcm
TTS_VOLC_SAMPLE_RATE=16000
TTS_VOLC_SPEED_RATIO=1.0
TTS_VOLC_VOLUME_RATIO=1.0
TTS_VOLC_PITCH_RATIO=1.0
TTS_VOLC_TIMEOUT=20s
